# 筑梦AI支教项目 - 环境变量配置示例
# 复制此文件为 .env 并修改相应配置

# ============ 服务器配置 ============
# 应用名称
APP_NAME=筑梦AI支教

# 应用版本
APP_VERSION=1.0.0

# 调试模式 (True/False)
DEBUG=True

# 服务器主机地址
HOST=0.0.0.0

# 服务器端口
PORT=8000


# ============ 数据库配置 ============
# MongoDB连接字符串
# 格式: mongodb://[用户名:密码@]主机:端口[/数据库名]
MONGODB_URI=mongodb://localhost:27017/dream-ai

# 生产环境示例:
# MONGODB_URI=mongodb://admin:password@mongodb:27017/dream-ai?authSource=admin


# ============ JWT配置 ============
# JWT密钥 (至少32个字符，生产环境必须修改!)
SECRET_KEY=your-secret-key-change-this-in-production-min-32-chars

# JWT算法
ALGORITHM=HS256

# 访问令牌过期时间 (分钟)
ACCESS_TOKEN_EXPIRE_MINUTES=10080  # 7天


# ============ CORS配置 ============
# 允许的跨域来源 (逗号分隔)
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:3000

# 生产环境示例:
# CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com


# ============ 文件上传配置 ============
# 上传文件保存目录
UPLOAD_DIR=./uploads

# 最大文件大小 (字节)
MAX_FILE_SIZE=10485760  # 10MB

# 允许的文件扩展名 (逗号分隔)
ALLOWED_EXTENSIONS=.jpg,.jpeg,.png,.gif,.pdf,.doc,.docx,.txt,.glb,.gltf


# ============ 邮件配置 (可选) ============
# SMTP服务器
# SMTP_HOST=smtp.gmail.com

# SMTP端口
# SMTP_PORT=587

# SMTP用户名
# SMTP_USER=your-email@gmail.com

# SMTP密码/应用专用密码
# SMTP_PASSWORD=your-password

# 发件人邮箱
# EMAIL_FROM=noreply@dream-ai.org

# 启用TLS
# SMTP_TLS=True


# ============ 其他配置 ============
# 日志级别 (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# 日志文件路径
LOG_FILE=./logs/app.log

# 访问日志文件路径
ACCESS_LOG_FILE=./logs/access.log

# 错误日志文件路径
ERROR_LOG_FILE=./logs/error.log


# ============ 生产环境注意事项 ============
# 1. 必须修改 SECRET_KEY
# 2. 设置 DEBUG=False
# 3. 配置正确的数据库连接
# 4. 配置正确的CORS来源
# 5. 配置邮件服务器 (如果需要邮件功能)
# 6. 确保上传目录有写入权限
# 7. 配置合适的日志级别和路径